# We use the .env.example file as a base for the .env file.
# Everything you define here (or using the environment flags set in docker)
# will override the default values in the .env.example file.
# Please study the .env.example file for more information about the variables.

# Which version of HAWKI do you run?
# While "latest" will always pull the latest version, it is HIGHLY RECOMMENDED to use a specific version tag here.
# Using a specific version tag ensures that you have a stable version and do not run into unexpected issues when a new version is released.
# You can find the available versions on Docker Hub: https://hub.docker.com/r/digitalenvironments/hawki/tags
PROJECT_HAWKI_IMAGE=digitalenvironments/hawki:latest # Works, but is not recommended for production! Use a specific version tag instead.

# Hosting variables
# based on these two variables, in production mode we automatically derive other
# variables, like: APP_URL, VITE_REVERB_HOST, DOCKER_PROJECT_HOST, DOCKER_PROJECT_PROTOCOL, etc.
APP_PROTOCOL=https # SET THIS TO http IF YOU DO NOT USE SSL!
APP_HOST=localhost # SET THIS TO YOUR DOMAIN!

# IMPORTANT VARIABLES YOU MUST SET TO SOMETHING ELSE!
DB_ROOT_PASSWORD=password # SET THIS TO SOMETHING SECURE!
DB_PASSWORD=password # SET THIS TO SOMETHING SECURE!
REDIS_PASSWORD=password # SET THIS TO SOMETHING SECURE!
APP_KEY=32charLongSecureAppKeyForEncrypt # SET THIS TO SOMETHING SECURE!
USERDATA_ENCRYPTION_SALT=base64:someRandomSalt== # SET THIS TO SOMETHING SECURE!
INVITATION_SALT=base64:someOtherRandomSalt== # SET THIS TO SOMETHING SECURE!
AI_CRYPTO_SALT=base64:someVeryCoolSalt== # SET THIS TO SOMETHING SECURE!
PASSKEY_SALT=base64:somePrettyAwesomeSalt== # SET THIS TO SOMETHING SECURE!
BACKUP_SALT=base64:someLegendarySalt== # SET THIS TO SOMETHING SECURE!
HAWKI_FILE_CONVERTER_API_KEY=password # SET THIS TO SOMETHING SECURE!

# Optional variables you may adjust to your needs but MUST be set.
PROJECT_NAME=hawki-prod
DB_USERNAME=hawki
DB_DATABASE=hawki
FILE_CONVERTER="hawki_converter"
HAWKI_FILE_CONVERTER_API_URL="http://file-converter:8001/extract"

# Debugging variables:

# Our base image automatically optimizes the PHP configuration for production.
# This means you can not easily modify the code and see the changes reflected in the container,
# because we use an opcode cache and other optimizations.
# You can disable those optimizations by setting the following variable to true.
# For more details see: https://github.com/Neunerlei/docker-images/blob/main/docs/php-nginx.md
#PHP_PROD_DEBUG=true

# Configuration for our docker-compose.yml
# Those variables SHOULD be kept as is, in order to work with the docker-compose.yml file.
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_USERNAME=default
REVERB_HOST=reverb
CACHE_STORE=redis
LOG_CHANNEL=stderr

# Add your own variables here
